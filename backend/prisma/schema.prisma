datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  AUTHOR
  REVIEWER
  EDITOR
  MANAGING_EDITOR
  ADMIN
}

enum ManuscriptStatus {
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUIRED
  ACCEPTED
  REJECTED
  PUBLISHED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  passwordHash  String
  firstName     String
  lastName      String
  affiliation   String
  orcid         String?            @unique
  role          Role               @default(AUTHOR)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  
  // Relations
  authorManuscripts   ManuscriptAuthor[]
  reviewerProfile     ReviewerProfile?
  editorAssignments   Manuscript[]       @relation("EditorAssigned")
  reviewsWritten      Review[]
  auditLogs           AuditLog[]
}

model ReviewerProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties     String[]           // Array of keywords representing scientific expertise
  isActive        Boolean            @default(true)
  score           Float              @default(5.0) // 1-5 calculated reviewer index
  
  // Relations
  invitations     ReviewInvitation[]
}

model Manuscript {
  id              String             @id @default(uuid())
  title           String
  abstract        String
  keywords        String[]
  status          ManuscriptStatus   @default(SUBMITTED)
  fileUrl         String             // Link to main Docx/PDF
  anonymizedFile  String?            // Link to peer-review ready PDF (exif metadata purged)
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  // Editor Assignment
  assignedEditorId String?
  assignedEditor   User?             @relation("EditorAssigned", fields: [assignedEditorId], references: [id])
  
  // Relations
  authors         ManuscriptAuthor[]
  reviews         Review[]
  invitations     ReviewInvitation[]
  article         Article?
}

model ManuscriptAuthor {
  id            String       @id @default(uuid())
  manuscriptId  String
  manuscript    Manuscript   @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  authorOrder   Int          // 1 for first author, 2 for second...
  isCorresponding Boolean    @default(false)

  @@unique([manuscriptId, userId])
}

model ReviewInvitation {
  id              String           @id @default(uuid())
  manuscriptId    String
  manuscript      Manuscript       @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  reviewerId      String
  reviewer        ReviewerProfile  @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  status          InviteStatus     @default(PENDING)
  createdAt       DateTime         @default(now())
  expiresAt       DateTime
  
  // Relations
  review          Review?
}

model Review {
  id                String            @id @default(uuid())
  invitationId      String            @unique
  invitation        ReviewInvitation  @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  manuscriptId      String
  manuscript        Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  reviewerId        String
  reviewer          User              @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  
  commentsToAuthor  String
  commentsToEditor  String
  scoreMethodology  Int               // 1-5 score
  scoreNovelty      Int               // 1-5 score
  scoreLanguage     Int               // 1-5 score
  plagiarismRisk    Float             @default(0.0) // 0-100% computed plagiarism risk
  recommendation    String            // ACCEPT, MINOR_REVISION, MAJOR_REVISION, REJECT
  isSubmitted       Boolean           @default(false)
  submittedAt       DateTime?
}

model Volume {
  id            String       @id @default(uuid())
  volumeNumber  Int          @unique
  year          Int
  description   String?
  isPublished   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  
  // Relations
  issues        Issue[]
}

model Issue {
  id            String       @id @default(uuid())
  volumeId      String
  volume        Volume       @relation(fields: [volumeId], references: [id])
  issueNumber   Int
  title         String?      // e.g. "Special Issue on Applied Machine Learning"
  isPublished   Boolean      @default(false)
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  
  // Relations
  articles      Article[]
}

model Article {
  id              String       @id @default(uuid())
  manuscriptId    String       @unique
  manuscript      Manuscript   @relation(fields: [manuscriptId], references: [id])
  issueId         String
  issue           Issue        @relation(fields: [issueId], references: [id])
  
  doi             String       @unique
  startPage       Int
  endPage         Int
  pdfUrl          String
  jatsUrl         String
  htmlContent     String       // Compiled markup / article body
  referencesList  String[]     // Parsed references
  citationCount   Int          @default(0)
  viewsCount      Int          @default(0)
  downloadsCount  Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  // Analytics Relations
  analytics       Analytics[]
}

model Analytics {
  id            String       @id @default(uuid())
  articleId     String
  article       Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  ipHash        String       // Anonymized IP hash
  countryCode   String
  isDownload    Boolean      @default(false)
  timestamp     DateTime     @default(now())
}

model AuditLog {
  id            String       @id @default(uuid())
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  action        String
  payload       String       // Hashed JSON detailing change
  timestamp     DateTime     @default(now())
  signature     String       // Cryptographic checksum of timestamp + userId + action + payload
}

model EmailLog {
  id            String       @id @default(uuid())
  to            String
  subject       String
  body          String
  status        String       // PENDING, SENT, FAILED
  attempts      Int          @default(0)
  errorMessage  String?
  createdAt     DateTime     @default(now())
  sentAt        DateTime?
}
